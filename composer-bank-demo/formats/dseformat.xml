<?xml version="1.0" encoding="ISO-8859-1"?>
<XML>
    <fmtDef id="LastTransactionsRQFmt">
        <CCXML dataName="LastTransactionsRequest">
            <CCString dataName="CustomerId"/>
            <CCString dataName="AccountId"/>
            <NumberFormat dataName="Limit" showThousandsSep="no" showDecimalsSep="no"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="LastTransactionsRSFmt">
        <CCXML dataName="LastTransactionsResponse">
            <CCTcoll dataName="Transactions" transparentSource="true" append="true" times="*">
                <CCXML dataName="Transaction">
                    <CCString dataName="TransactionId"/>
                    <CCDate dataName="BookedAt" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
                    <CCString dataName="Description"/>
                    <NumberFormat dataName="Amount" showThousandsSep="no" showDecimalsSep="yes"/>
                    <CCString dataName="Currency"/>
                </CCXML>
            </CCTcoll>
        </CCXML>
    </fmtDef>

    <fmtDef id="GetCreditCardListRQFmt">
        <CCXML dataName="GetCreditCardListRequest">
            <CCString dataName="CustomerId"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="GetCreditCardListRSFmt">
        <CCXML dataName="GetCreditCardListResponse">
            <CCTcoll dataName="Cards" transparentSource="true" append="true" times="*">
                <CCXML dataName="Card">
                    <CCString dataName="CardId"/>
                    <CCString dataName="MaskedNumber"/>
                    <CCString dataName="Brand"/>
                    <CCString dataName="Status"/>
                    <NumberFormat dataName="AvailableCredit" showThousandsSep="no" showDecimalsSep="yes"/>
                </CCXML>
            </CCTcoll>
        </CCXML>
    </fmtDef>

    <fmtDef id="GetCreditCardTransactionsRQFmt">
        <CCXML dataName="GetCreditCardTransactionsRequest">
            <CCString dataName="CustomerId"/>
            <CCString dataName="CardId"/>
            <CCDate dataName="FromDate" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
            <CCDate dataName="ToDate" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="GetCreditCardTransactionsRSFmt">
        <CCXML dataName="GetCreditCardTransactionsResponse">
            <CCTcoll dataName="CardTransactions" transparentSource="true" append="true" times="*">
                <CCXML dataName="CardTransaction">
                    <CCString dataName="TransactionId"/>
                    <CCDate dataName="TransactionDate" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
                    <CCString dataName="MerchantName"/>
                    <NumberFormat dataName="Amount" showThousandsSep="no" showDecimalsSep="yes"/>
                    <CCString dataName="Currency"/>
                </CCXML>
            </CCTcoll>
        </CCXML>
    </fmtDef>

    <fmtDef id="ListLoansRQFmt">
        <CCXML dataName="ListLoansRequest">
            <CCString dataName="CustomerId"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="ListLoansRSFmt">
        <CCXML dataName="ListLoansResponse">
            <CCTcoll dataName="Loans" transparentSource="true" append="true" times="*">
                <CCXML dataName="Loan">
                    <CCString dataName="LoanId"/>
                    <CCString dataName="LoanType"/>
                    <NumberFormat dataName="OutstandingBalance" showThousandsSep="no" showDecimalsSep="yes"/>
                    <NumberFormat dataName="MonthlyPayment" showThousandsSep="no" showDecimalsSep="yes"/>
                    <CCDate dataName="NextPaymentDate" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
                </CCXML>
            </CCTcoll>
        </CCXML>
    </fmtDef>

    <fmtDef id="GetAccountBalanceRQFmt">
        <CCXML dataName="GetAccountBalanceRequest">
            <CCString dataName="CustomerId"/>
            <CCString dataName="AccountId"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="GetAccountBalanceRSFmt">
        <CCXML dataName="GetAccountBalanceResponse">
            <CCString dataName="AccountId"/>
            <NumberFormat dataName="CurrentBalance" showThousandsSep="no" showDecimalsSep="yes"/>
            <NumberFormat dataName="AvailableBalance" showThousandsSep="no" showDecimalsSep="yes"/>
            <CCString dataName="Currency"/>
            <CCDate dataName="AsOfDate" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
        </CCXML>
    </fmtDef>

    <fmtDef id="TransferFundsRQFmt">
        <CCXML dataName="TransferFundsRequest">
            <CCString dataName="CustomerId"/>
            <CCString dataName="FromAccountId"/>
            <CCString dataName="ToAccountId"/>
            <NumberFormat dataName="Amount" showThousandsSep="no" showDecimalsSep="yes"/>
            <CCString dataName="Currency"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="TransferFundsRSFmt">
        <CCXML dataName="TransferFundsResponse">
            <CCString dataName="TransferId"/>
            <CCString dataName="Status"/>
            <CCDate dataName="ProcessedAt" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
        </CCXML>
    </fmtDef>

    <fmtDef id="PayBillRQFmt">
        <CCXML dataName="PayBillRequest">
            <CCString dataName="CustomerId"/>
            <CCString dataName="BillerId"/>
            <CCString dataName="FromAccountId"/>
            <NumberFormat dataName="Amount" showThousandsSep="no" showDecimalsSep="yes"/>
            <CCString dataName="ReferenceNumber"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="PayBillRSFmt">
        <CCXML dataName="PayBillResponse">
            <CCString dataName="PaymentId"/>
            <CCString dataName="Status"/>
            <CCDate dataName="ProcessedAt" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
        </CCXML>
    </fmtDef>

    <fmtDef id="GetStandingOrdersRQFmt">
        <CCXML dataName="GetStandingOrdersRequest">
            <CCString dataName="CustomerId"/>
            <CCString dataName="AccountId"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="GetStandingOrdersRSFmt">
        <CCXML dataName="GetStandingOrdersResponse">
            <CCTcoll dataName="StandingOrders" transparentSource="true" append="true" times="*">
                <CCXML dataName="StandingOrder">
                    <CCString dataName="StandingOrderId"/>
                    <CCString dataName="BeneficiaryName"/>
                    <NumberFormat dataName="Amount" showThousandsSep="no" showDecimalsSep="yes"/>
                    <CCString dataName="Frequency"/>
                    <CCDate dataName="NextRunDate" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
                </CCXML>
            </CCTcoll>
        </CCXML>
    </fmtDef>

    <fmtDef id="CreateLoanQuoteRQFmt">
        <CCXML dataName="CreateLoanQuoteRequest">
            <CCString dataName="CustomerId"/>
            <NumberFormat dataName="RequestedAmount" showThousandsSep="no" showDecimalsSep="yes"/>
            <NumberFormat dataName="TermMonths" showThousandsSep="no" showDecimalsSep="no"/>
            <CCString dataName="Purpose"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="CreateLoanQuoteRSFmt">
        <CCXML dataName="CreateLoanQuoteResponse">
            <CCString dataName="QuoteId"/>
            <NumberFormat dataName="InterestRate" showThousandsSep="no" showDecimalsSep="yes"/>
            <NumberFormat dataName="EstimatedMonthlyPayment" showThousandsSep="no" showDecimalsSep="yes"/>
            <CCDate dataName="ValidUntil" pattern="yyyyMMdd" useSep="no" fourDigYear="yes" ordering="ymd" usePattern="yes" onFailed="current"/>
        </CCXML>
    </fmtDef>

    <fmtDef id="GetCustomerProfileRQFmt">
        <CCXML dataName="GetCustomerProfileRequest">
            <CCString dataName="CustomerId"/>
        </CCXML>
    </fmtDef>
    <fmtDef id="GetCustomerProfileRSFmt">
        <CCXML dataName="GetCustomerProfileResponse">
            <CCString dataName="CustomerId"/>
            <CCString dataName="FullName"/>
            <CCString dataName="Email"/>
            <CCString dataName="MobilePhone"/>
            <CCString dataName="PreferredLanguage"/>
            <CCBoolean dataName="MarketingConsent"/>
        </CCXML>
    </fmtDef>
</XML>
