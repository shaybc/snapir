%%{init: {'flowchart': {'defaultRenderer': 'elk'}}}%%
flowchart LR

%% =========================
%% Styles
%% =========================
classDef phase fill:#263238,color:#ffffff,stroke:#111111,stroke-width:1px
classDef agent fill:#e3f2fd,color:#0d47a1,stroke:#1565c0,stroke-width:1px
classDef parallel fill:#fff3e0,color:#e65100,stroke:#ef6c00,stroke-width:1px
classDef loop fill:#f3e5f5,color:#4a148c,stroke:#7b1fa2,stroke-width:1px
classDef tool fill:#eeeeee,color:#212121,stroke:#616161,stroke-width:1px
classDef db fill:#e8f5e9,color:#1b5e20,stroke:#2e7d32,stroke-width:1px
classDef gate fill:#fffde7,color:#827717,stroke:#f9a825,stroke-width:2px
classDef fail fill:#ffebee,color:#b71c1c,stroke:#c62828,stroke-width:1px
classDef success fill:#e8f5e9,color:#1b5e20,stroke:#2e7d32,stroke-width:1px

%% =========================
%% Phase Entry
%% =========================
P3["Phase 3 Agent Block<br/>Operation Flow Conversion<br/><br/>Convert each operation opStep graph<br/>into native Java switch-on-rc orchestration"]:::phase

%% =========================
%% Dispatch / Batch Layer
%% =========================
subgraph DISPATCH_LAYER["Dispatch + Batch Control"]
  direction LR

  DISP["OperationBatchDispatcherAgent<br/><br/>Type: LlmAgent tool-wrapper<br/>Pages operation list from DB<br/>Dispatches bounded batches"]:::agent

  BATCH["OperationBatchAgent<br/><br/>Type: ParallelAgent<br/>Runs MAX_PARALLEL_OPERATIONS<br/>conversions concurrently"]:::parallel
end

P3 --> DISP --> BATCH

%% =========================
%% Parallel Worker Layer
%% =========================
subgraph WORKER_LAYER["Parallel Operation Conversion Workers"]
  direction TB

  SLOT0["OperationFlowConverterAgent<br/>slot 0<br/><br/>Type: LlmAgent"]:::agent
  SLOT1["OperationFlowConverterAgent<br/>slot 1<br/><br/>Type: LlmAgent"]:::agent
  SLOTN["OperationFlowConverterAgent<br/>slot N<br/><br/>Type: LlmAgent"]:::agent
end

BATCH --> SLOT0
BATCH --> SLOT1
BATCH --> SLOTN

%% =========================
%% Shared Tool Layer
%% =========================
subgraph FLOWTOOLS["Shared Flow Converter Tools"]
  direction TB

  READ[("read_file_tool")]:::tool
  WRITE[("write_file_tool")]:::tool
  GRAPH[("dependency_graph_tool<br/>query_dependency_graph")]:::tool
  COMPREG[("component_registry_tool<br/>get_generated_path")]:::tool
  SEM[("tag_semantics_tool<br/>get_tag_semantics")]:::tool
  DEPCHECK[("dependency_check_tool<br/>scan_for_forbidden_imports")]:::tool
  DB2[("state_store_tool<br/>get/set checkpoint")]:::db
end

SLOT0 -. "uses" .-> FLOWTOOLS
SLOT1 -. "uses" .-> FLOWTOOLS
SLOTN -. "uses" .-> FLOWTOOLS

%% =========================
%% Refinement Loop Layer
%% =========================
subgraph REFINEMENT_LAYER["Refinement + Validation Loop"]
  direction TB

  LOOP["OperationRefinementLoopAgent<br/><br/>Type: LoopAgent<br/>critic → compile retry<br/>until success or MAX_LOOP_RETRIES"]:::loop

  CRITIC["ConversionCriticAgent<br/><br/>Type: LlmAgent<br/>Reviews flow correctness<br/>rc coverage, context usage<br/>IBM dependency removal"]:::agent

  COMPILE["ConversionCompileAgent<br/><br/>Type: LlmAgent tool-wrapper<br/>Runs mvn compile<br/>on generated operation flow"]:::agent

  MVN[("maven_compile_tool<br/>Pure Python")]:::tool
end

SLOT0 --> LOOP
SLOT1 --> LOOP
SLOTN --> LOOP

LOOP --> CRITIC
LOOP --> COMPILE

CRITIC -. "checks imports" .-> DEPCHECK
COMPILE -. "runs" .-> MVN

%% =========================
%% State Store / DB
%% =========================
DB[("state_store_tool<br/>migration DB")]:::db

DISP -. "page operations" .-> DB
CRITIC -. "write review result" .-> DB
COMPILE -. "write compile result" .-> DB
DB2 -. "checkpoint state" .-> DB

%% =========================
%% Outcomes
%% =========================
subgraph OUTCOME_LAYER["Operation Outcome"]
  direction TB

  DONE[("DB checkpoint<br/>OPERATION_FLOW_CONVERTED<br/>OPERATION_FLOW_COMPILED")]:::success

  FAILED[("operation status = FAILED<br/>store compiler / critic errors")]:::fail
end

LOOP -->|success| DONE
LOOP -->|max retries failed| FAILED

%% =========================
%% Human Gate
%% =========================
G3["HumanApprovalAgent Gate 3<br/><br/>Review sample batch<br/>of operation flows"]:::gate

DONE --> G3
FAILED --> G3