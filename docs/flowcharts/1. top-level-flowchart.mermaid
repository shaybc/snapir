%%{init: {'flowchart': {'defaultRenderer': 'elk'}}}%%
flowchart LR

%% =========================
%% Styles
%% =========================
classDef root fill:#,color:#0d47a1,stroke:#111111,stroke-width:2px
classDef phase fill:#e3f2fd,color:#0d47a1,stroke:#1565c0,stroke-width:1px
classDef agent fill:#f5f5f5,color:#212121,stroke:#616161,stroke-width:1px
classDef loop fill:#f3e5f5,color:#4a148c,stroke:#7b1fa2,stroke-width:1px
classDef parallel fill:#fff3e0,color:#e65100,stroke:#ef6c00,stroke-width:1px
classDef tool fill:#eeeeee,color:#212121,stroke:#424242,stroke-width:1px
classDef db fill:#e8f5e9,color:#1b5e20,stroke:#2e7d32,stroke-width:1px
classDef gate fill:#fffde7,color:#827717,stroke:#f9a825,stroke-width:2px
classDef final fill:#e0f7fa,color:#006064,stroke:#00838f,stroke-width:2px

%% =========================
%% Root
%% =========================
ROOT["RootMigrationOrchestratorAgent<br/><br/>Type: SequentialAgent<br/>Orchestrates all phases,<br/>approval gates, and resume flow"]:::root

DB[("state_store_tool<br/>migration DB")]:::db

ROOT -. "checkpoint / resume state" .-> DB

%% =========================
%% Phase 0 - Inventory
%% =========================
subgraph P0["Phase 0 — Inventory Discovery"]
  direction TB

  INV["InventoryCoordinatorAgent<br/><br/>Type: SequentialAgent"]:::phase

  XML["XmlInventoryToolAgent<br/>Type: LlmAgent tool-wrapper"]:::agent
  DSE["DseIniInventoryToolAgent<br/>Type: LlmAgent tool-wrapper"]:::agent
  JAVA["JavaInventoryToolAgent<br/>Type: LlmAgent tool-wrapper"]:::agent
  AMBIG["InventoryAmbiguityResolverAgent<br/>Type: LlmAgent"]:::agent

  XMLT[("xml_parser_tool")]:::tool
  DSET[("dse_ini_parser_tool")]:::tool
  CROSS[("cross_validate_tool")]:::tool
  JAVAT[("java_source_scanner_tool")]:::tool

  INV --> XML
  INV --> DSE
  INV --> JAVA
  INV --> AMBIG

  XML -. "uses" .-> XMLT
  DSE -. "uses" .-> DSET
  DSE -. "cross-validates" .-> CROSS
  JAVA -. "uses" .-> JAVAT
end

ROOT --> INV
INV -. "write inventory" .-> DB

G0["HumanApprovalAgent<br/>Gate 0<br/><br/>Approve inventory baseline"]:::gate
INV --> G0

%% =========================
%% Phase 1 - Dependency Graph
%% =========================
subgraph P1["Phase 1 — Dependency Graph Construction"]
  direction TB

  DEP["DependencyGraphCoordinatorAgent<br/><br/>Type: LlmAgent tool-wrapper"]:::phase

  OPDEP["OperationDependencyAgent"]:::agent
  FMTDEP["FormatDependencyAgent"]:::agent
  CTXDEP["ContextDependencyAgent"]:::agent
  JDEP["JavaImplDependencyAgent"]:::agent

  GRAPHT[("dependency_graph_tool")]:::tool

  DEP --> OPDEP
  DEP --> FMTDEP
  DEP --> CTXDEP
  DEP --> JDEP

  OPDEP -. "writes graph" .-> GRAPHT
  FMTDEP -. "writes graph" .-> GRAPHT
  CTXDEP -. "writes graph" .-> GRAPHT
  JDEP -. "scans Java refs" .-> JAVAT
end

G0 --> DEP
DEP -. "write dependency graph" .-> DB

%% =========================
%% Phase 2 - Shared Components
%% =========================
subgraph P2["Phase 2 — Shared Component Conversion"]
  direction TB

  SHARED["SharedComponentCoordinatorAgent<br/><br/>Type: SequentialAgent"]:::phase

  JCONV["JavaClassConverterAgent<br/>Type: LlmAgent"]:::agent
  FCONV["FormatConverterAgent<br/>Type: LlmAgent"]:::agent
  XMLSER["XmlSerializerGeneratorAgent<br/>Type: LlmAgent"]:::agent
  CCONV["ContextConverterAgent<br/>Type: LlmAgent"]:::agent
  DBREPO["DbRepositoryGeneratorAgent<br/>Type: LlmAgent"]:::agent

  SERPLAN[("xml_serializer_strategy_tool")]:::tool
  COMPREG[("component_registry_tool")]:::db

  LOOP1["SharedComponentRefinementLoopAgent<br/><br/>Type: LoopAgent<br/>critic → compile retry"]:::loop

  CRITIC["ConversionCriticAgent<br/>Type: LlmAgent"]:::agent
  COMPILE["ConversionCompileAgent<br/>Type: tool-wrapper"]:::agent

  DEPCHECK[("dependency_check_tool")]:::tool
  MVN[("maven_compile_tool")]:::tool

  SHARED --> JCONV
  SHARED --> FCONV
  FCONV --> XMLSER
  XMLSER -. "strategy" .-> SERPLAN
  SHARED --> CCONV
  SHARED --> DBREPO
  SHARED --> LOOP1

  SHARED -. "register generated components" .-> COMPREG

  LOOP1 --> CRITIC
  LOOP1 --> COMPILE

  CRITIC -. "checks forbidden imports" .-> DEPCHECK
  COMPILE -. "runs compile" .-> MVN
end

DEP --> SHARED
SHARED -. "write shared conversion status" .-> DB

G2["HumanApprovalAgent<br/>Gate 2<br/><br/>Approve shared components"]:::gate
SHARED --> G2

%% =========================
%% Phase 2.5 - Common Library Build
%% =========================
subgraph P25["Phase 2.5 — Common Library Build"]
  direction TB

  CLB["CommonLibBuildAgent<br/><br/>Type: tool-wrapper"]:::phase
  CLB -. "build common library" .-> MVN
end

G2 --> CLB
CLB -. "write build result" .-> DB

%% =========================
%% Phase 3 Preparation - Tag Semantics
%% =========================
subgraph P3PREP["Phase 3 Prep — Tag Semantics Extraction"]
  direction TB

  SEM["TagSemanticsCoordinatorAgent<br/><br/>Type: SequentialAgent"]:::phase

  SEMEXT["TagSemanticExtractorAgent<br/>Type: LlmAgent"]:::agent
  SEMCRIT["TagSemanticCriticAgent<br/>Type: LlmAgent"]:::agent

  SEMDB[("tag_semantics_tool<br/>DB")]:::db

  SEM --> SEMEXT
  SEM --> SEMCRIT

  SEMEXT -. "reads XML definitions" .-> XMLT
  SEMEXT -. "reads Java sources" .-> JAVAT
  SEMEXT -. "stores semantics" .-> SEMDB
end

CLB --> SEM
SEM -. "write semantic extraction status" .-> DB

%% =========================
%% Phase 3 - Operation Flow Conversion
%% =========================
subgraph P3["Phase 3 — Operation Flow Conversion"]
  direction TB

  BATCH["OperationBatchDispatcherAgent<br/><br/>Type: tool-wrapper"]:::phase

  PAR["OperationBatchAgent<br/>Type: ParallelAgent"]:::parallel

  FLOW["OperationFlowConverterAgent<br/><br/>Type: LlmAgent<br/>slots 0..N"]:::agent

  LOOP2["OperationRefinementLoopAgent<br/><br/>Type: LoopAgent<br/>critic → compile retry"]:::loop

  BATCH --> PAR --> FLOW --> LOOP2

  FLOW -. "uses tag semantics" .-> SEMDB
  FLOW -. "uses component registry" .-> COMPREG

  LOOP2 --> CRITIC
  LOOP2 --> COMPILE
end

SEM --> BATCH
BATCH -. "write operation conversion status" .-> DB

G3["HumanApprovalAgent<br/>Gate 3<br/><br/>Review sample batch<br/>of operation flows"]:::gate
BATCH --> G3

%% =========================
%% Phase 4 - Spring Boot Service Generation
%% =========================
subgraph P4["Phase 4 — Spring Boot + OpenShift Generation"]
  direction TB

  SB["SpringBootServiceGeneratorAgent<br/><br/>Type: SequentialAgent"]:::phase

  CTRL["ControllerGeneratorAgent<br/>Type: LlmAgent"]:::agent
  SVC["ServiceGeneratorAgent<br/>Type: LlmAgent"]:::agent
  OS["OpenShiftManifestAgent<br/>Type: LlmAgent"]:::agent

  RW[("read_file_tool<br/>write_file_tool")]:::tool
  YAML[("yaml_validator_tool")]:::tool

  SB --> CTRL
  SB --> SVC
  SB --> OS

  CTRL -. "read/write files" .-> RW
  SVC -. "read/write files" .-> RW
  OS -. "read/write manifests" .-> RW
  OS -. "validate YAML" .-> YAML
end

G3 --> SB

%% =========================
%% Phase 5 - Compile + XML Compatibility + Final Review
%% =========================
subgraph P5["Phase 5 — Compile, Compatibility, Final Review"]
  direction TB

  TEST["ServiceCompileTestAgent<br/><br/>Type: tool-wrapper"]:::phase
  XMLCOMP["XmlCompatibilityAgent<br/><br/>Type: tool-wrapper"]:::phase
  FINAL["FinalReviewAgent<br/><br/>Type: LlmAgent"]:::final

  GOLDEN[("xml_golden_test_tool")]:::tool

  TEST -. "compile generated services" .-> MVN
  XMLCOMP -. "run XML compatibility tests" .-> GOLDEN

  TEST --> XMLCOMP --> FINAL
end

SB --> TEST

TEST -. "write compile test status" .-> DB
XMLCOMP -. "write XML compatibility status" .-> DB
FINAL -. "write final review status" .-> DB

G5["HumanApprovalAgent<br/>Gate 5<br/><br/>Approve final migration package"]:::gate
FINAL --> G5

%% =========================
%% Phase 6 - Behavioral Equivalence
%% =========================
subgraph P6["Phase 6 — Behavioral Equivalence"]
  direction TB

  BECOORD["BehavioralEquivalenceCoordinatorAgent<br/><br/>Type: SequentialAgent"]:::phase

  BE["BehavioralEquivalenceAgent<br/>Type: tool-wrapper"]:::agent

  BETEST[("behavioral_test_tool")]:::tool
  XMLDIFF[("xml_diff_tool")]:::tool

  BECOORD --> BE
  BE -. "run behavior tests" .-> BETEST
  BE -. "compare XML outputs" .-> XMLDIFF
end

G5 --> BECOORD
BE -. "write equivalence result" .-> DB